############################################
# AUTH & SECURITY
############################################
# 64 hex chars = 32 bytes AES-256-GCM key for WhatsApp token encryption.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this value orphans every stored token — users must re-save WhatsApp settings.
ENCRYPTION_KEY=e1174f5b6639412a758f3af20c4033af03824dc612fe89e55d66b53a5cb977f8

# Canonical public URL (scheme + host, no trailing slash).
# Used for sitemap, OG images, and invite link generation.
NEXT_PUBLIC_SITE_URL=

############################################
# AI PROVIDERS
############################################
# Primary: OpenRouter (https://openrouter.ai) — gives access to all models below
# Model string, e.g: google/gemini-2.5-flash:free, meta-llama/llama-3.3-70b-instruct:free
AI_MODEL=google/gemini-2.5-flash:free

############################################
# APPLICATION
############################################
PORT=3000
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
