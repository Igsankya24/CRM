{
  "name": "crm-with-ai-integration",
  "version": "1.0.0",
  "private": true,
  "description": "CRM with WhatsApp automation and AI integration — shared inbox, contacts, sales pipelines, broadcasts, automations, and multi-provider AI agent. Built on Next.js and Supabase.",
  "license": "MIT",
  "keywords": [
    "crm",
    "whatsapp",
    "whatsapp-business-api",
    "nextjs",
    "supabase",
    "ai",
    "openai",
    "openrouter",
    "automation",
    "broadcast",
    "self-hosted"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev --webpack",
    "build": "node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "typecheck": "node node_modules/typescript/lib/tsc.js --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:watch": "node node_modules/vitest/vitest.mjs"
  },
