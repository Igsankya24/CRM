    "next-themes": "^0.4.6",
    "openai": "^6.32.0",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-is": "^19.2.7",
    "recharts": "^3.8.1",
    "shadcn": "^4.10.0",
